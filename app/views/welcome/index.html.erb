<div class="welcome">
  <h1>🚀 Rails on the Cloud</h1>
  <p class="lede">
    A minimal Rails <%= Rails.version %> app, containerized and ready to deploy.
  </p>

  <div class="cards">
    <div class="card">
      <h2>Notes</h2>
      <p>A working, database-backed resource (SQLite).</p>
      <p class="count"><%= @notes_count %> note<%= "s" unless @notes_count == 1 %> so far.</p>
      <%= link_to "Open Notes →", notes_path, class: "btn" %>
    </div>

    <div class="card">
      <h2>Health check</h2>
      <p>Load balancers and uptime monitors hit this endpoint.</p>
      <%= link_to "GET /up →", rails_health_check_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <footer class="env">
    <span>Ruby <%= RUBY_VERSION %></span>
    <span>Rails <%= Rails.version %></span>
    <span>Env: <%= Rails.env %></span>
  </footer>
</div>

<style>
  .welcome { max-width: 720px; margin: 4rem auto; padding: 0 1.5rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1f2937; }
  .welcome h1 { font-size: 2.25rem; margin-bottom: .5rem; }
  .lede { font-size: 1.125rem; color: #6b7280; margin-bottom: 2.5rem; }
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .card { border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.5rem; background: #fff; }
  .card h2 { margin: 0 0 .5rem; font-size: 1.25rem; }
  .card p { color: #4b5563; margin: 0 0 .75rem; font-size: .95rem; }
  .count { font-weight: 600; color: #111827; }
  .btn { display: inline-block; padding: .5rem 1rem; border-radius: 8px; background: #ef4444; color: #fff; text-decoration: none; font-size: .9rem; }
  .btn-secondary { background: #374151; }
  .env { margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; font-size: .8rem; color: #9ca3af; }
  .env span { background: #f3f4f6; padding: .25rem .6rem; border-radius: 6px; }
  @media (max-width: 560px) { .cards { grid-template-columns: 1fr; } }
</style>
